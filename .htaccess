# drsp.cc redirect rules (static site)
RewriteEngine On

# 404 Custom Page
ErrorDocument 404 /404.html

# Legacy service paths
RedirectMatch 301 ^/eiri/membership/?$ /membership/
RedirectMatch 301 ^/eiri/membership/kiyaku/?$ /membership/kiyaku/
RedirectMatch 301 ^/eiri/1on1/?$ /eiri/
RedirectMatch 301 ^/eiri/redesign/?$ /eiri/

# Legacy app paths
RedirectMatch 301 ^/chat(/.*)?$ /app/chat$1
RedirectMatch 301 ^/dic(/.*)?$ /app/dic$1
RedirectMatch 301 ^/mng(/.*)?$ /app/mng$1
RedirectMatch 301 ^/note(/.*)?$ /app/note$1
RedirectMatch 301 ^/app/pj$ /app/pj/
RedirectMatch 301 ^/pj$ /app/pj/
RedirectMatch 301 ^/pj/(.*)$ /app/pj/$1

# Legacy WordPress endpoints & system paths (Batch)
RedirectMatch 301 ^/index\.php$ /
RedirectMatch 301 ^/xmlrpc\.php$ /
RedirectMatch 301 ^/wp-.*$ /
RedirectMatch 301 ^/feed/?$ /
RedirectMatch 301 ^/comments/feed/?$ /

# Legacy WordPress Author / Category / Tag / Date
RedirectMatch 301 ^/archives/author/.*$ /member/
RedirectMatch 301 ^/archives/category/.*$ /hieiri/
RedirectMatch 301 ^/archives/tag/.*$ /hieiri/
RedirectMatch 301 ^/archives/date/.*$ /hieiri/

# Legacy article URLs (covers numeric IDs and any other /archives/ path)
RedirectMatch 301 ^/archives/.*$ /hieiri/

# Legacy FAQ page
RedirectMatch 301 ^/faq/?$ /inquiry/

# Browser cache policy for static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType application/x-javascript "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/avif "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(?:css|js|mjs|map|webp|avif|svg|png|jpe?g|gif|ico|woff2?|ttf|otf)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(?:html?)$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>
